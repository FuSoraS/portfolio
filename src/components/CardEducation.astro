---
interface Props {
    title: string;
    date: string;
    content: string;
}

const { title, date, content } = Astro.props;
---
<article class="container-education">
    <div class="container-title">
        <div class="container-img">
            <slot name="icon" />
        </div>
        <h3>{title}</h3>
    </div>
    <p class="date">{date}</p>
    <p>{content}</p>
</article>

<style>
    .date {
        color: light-dark(#474747, #C0C0C0);
        margin: 5px 0 15px;
    }

    .container-title {
        display: flex;
        align-items: center;
    }

    .container-img {
        --size: 40px;

        display: flex;
        align-items: center;
        justify-content: center;
        height: var(--size);
        width: var(--size);
        background-color: #D9D9D9;
        margin-right: 10px;
        border-radius: 10px;
        padding: 1px;
    }

    .container-img :global(svg) {
        --size: 35px;

        color: #000;
        width: var(--size);
        height: var(--size);
    }

    .container-education {
        margin-bottom: 20px;
    }

    h3 {
        margin-block: 0.5em;
    }
</style>