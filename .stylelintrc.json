{
  "extends": [
    "stylelint-config-standard",
    "stylelint-config-html",
    "stylelint-config-html/astro"
  ],
  "ignoreFiles": [
    "**/*.json",
    "**/*.ts",
    "**/assets/**"
  ],
  "rules": {
    "selector-pseudo-class-no-unknown": [
      true,
      {
        "ignorePseudoClasses": ["global"]
      }
    ]
  }
}